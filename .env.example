# Example environment variables — copy to .env.<environment> and fill in real values
# See docs/self-hosting.md for setup instructions

# Rails inbound email (Action Mailbox)
# This is the password used between postfix and Rails. Use any random string.
# You can use "openssl rand -hex 32" for this.
RAILS_INBOUND_EMAIL_PASSWORD=

# SMTP (e.g. Amazon SES)
SMTP_ADDRESS=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USER_NAME=
SMTP_PASSWORD=

# Inbound email parser account. It can be anything, as long as it matches the LLM server configuration. 
PARSER_EMAIL=
PARSER_PASSWORD=

# Use "openssl rand -hex 64"
SECRET_KEY_BASE=

# Rails time zone string (e.g. Europe/Amsterdam, America/New_York)
TIME_ZONE=

# Display name for the app
APP_NAME=My Newsletter Hub

# Your app's public hostname (e.g. newsletters.example.com)
APP_HOST=

# The first user (admin)
INITIAL_ADMIN_EMAIL=you@example.com

DEFAULT_FROM_EMAIL=hello@example.com

#I add the prefix "secret-" to show that this email is how I identify the venues, so they should keep this email to themselves.
EMAIL_PREFIX_PATTERN=secret-

# Inbound email — venues email newsletters to: <prefix><code>@inbox.example.com
VENUE_EMAIL_DOMAIN=inbox.example.com

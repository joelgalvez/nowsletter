<% content_for :title, "Showing llm job" %>

<div class="crud">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <h1 class="font-bold text-4xl">Showing llm job</h1>

  <%= render @llm_job %>

  <% if @llm_job.substitutes.any? %>
    <div class="my-6">
      <h2 class="font-bold text-xl mb-2">Substitutes</h2>
      <table class="min-w-full divide-y divide-gray-200 text-sm border border-gray-200 rounded">
        <thead class="bg-gray-50">
          <tr class="text-left text-gray-500 uppercase text-xs">
            <th class="py-2 px-3">Short</th>
            <th class="py-2 px-3">Long</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @llm_job.substitutes.order(:id).each do |sub| %>
            <tr>
              <td class="py-2 px-3 whitespace-nowrap font-mono text-gray-700"><%= sub.short %></td>
              <td class="py-2 px-3 text-gray-600 break-all"><%= sub.long %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <%= link_to "Edit this llm job", edit_llm_job_path(@llm_job), class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
  <%= link_to "Back to llm jobs", llm_jobs_path, class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
  <%= button_to "Destroy this llm job", @llm_job, method: :delete, form_class: "sm:inline-block mt-2 sm:mt-0 sm:ml-2", class: "w-full rounded-md px-3.5 py-2.5 text-white bg-red-600 hover:bg-red-500 font-medium cursor-pointer", data: { turbo_confirm: "Are you sure?" } %>
</div>

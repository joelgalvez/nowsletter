<% content_for :title, "Llm jobs" %>

<div class="crud">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center mb-6">
    <h1 class="font-bold text-4xl">LLM Jobs</h1>
    <%= link_to "New LLM job", new_llm_job_path, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium" %>
  </div>

  <% if @llm_jobs.any? %>
    <table class="min-w-full divide-y divide-gray-200 text-sm">
      <thead>
        <tr class="text-left text-gray-500 uppercase text-xs">
          <th class="py-2 pr-4 whitespace-nowrap">Date</th>
          <th class="py-2 pr-4">Letter</th>
          <th class="py-2 pr-4">Status</th>
          <th class="py-2 pr-4 w-1/3">Prompt</th>
          <th class="py-2 pr-4 w-1/3">Response</th>
          <th class="py-2 pr-4">Model</th>
          <th class="py-2 pr-4">Seconds</th>
          <th class="py-2 pr-4">Subs</th>
          <th class="py-2"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @llm_jobs.each do |llm_job| %>
          <% status_class = case llm_job.status
            when "new"       then "bg-gray-100 text-gray-600"
            when "pending"   then "bg-yellow-100 text-yellow-700"
            when "parsed"    then "bg-blue-100 text-blue-700"
            when "processed" then "bg-green-100 text-green-700"
            when "error"     then "bg-red-100 text-red-700"
            else "bg-gray-100 text-gray-600"
            end %>
          <tr>
            <td class="py-2 pr-4 whitespace-nowrap text-gray-500 text-xs"><%= llm_job.created_at.strftime("%Y-%m-%d %H:%M") %></td>
            <td class="py-2 pr-4 max-w-[12rem]"><%= link_to truncate(llm_job.letter.subject, length: 40), dashboard_letter_path(llm_job.letter), class: "text-blue-600 hover:underline block truncate" %></td>
            <td class="py-2 pr-4 whitespace-nowrap"><span class="rounded px-2 py-0.5 text-xs font-medium <%= status_class %>"><%= llm_job.status %></span></td>
            <td class="py-2 pr-4 text-gray-700 max-w-xs"><span class="block truncate"><%= truncate(llm_job.prompt, length: 60) %></span></td>
            <td class="py-2 pr-4 text-gray-500 max-w-xs"><span class="block truncate"><%= truncate(llm_job.result, length: 60) %></span></td>
            <td class="py-2 pr-4 text-gray-500 whitespace-nowrap"><%= llm_job.model %></td>
            <td class="py-2 pr-4 text-gray-500 whitespace-nowrap"><%= llm_job.seconds %></td>
            <td class="py-2 pr-4 text-gray-500 whitespace-nowrap"><%= llm_job.substitutes.size %></td>
            <td class="py-2 text-right whitespace-nowrap space-x-2">
              <%= link_to "Show", llm_job, class: "rounded px-2.5 py-1.5 bg-gray-100 hover:bg-gray-200 font-medium" %>
              <%= link_to "Edit", edit_llm_job_path(llm_job), class: "rounded px-2.5 py-1.5 bg-gray-100 hover:bg-gray-200 font-medium" %>
              <%= button_to "Delete", llm_job, method: :delete, class: "rounded px-2.5 py-1.5 text-white bg-red-600 hover:bg-red-500 font-medium cursor-pointer", data: { turbo_confirm: "Are you sure?" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <div class="mt-6">
      <%= paginate @llm_jobs %>
    </div>
  <% else %>
    <p class="text-center my-10 text-gray-500">No LLM jobs found.</p>
  <% end %>
</div>

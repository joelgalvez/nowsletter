<% content_for :title, "Editing llm job" %>

<div class="crud">
  <h1 class="font-bold text-4xl">Editing llm job</h1>

  <%= render "form", llm_job: @llm_job %>

  <%= link_to "Show this llm job", @llm_job, class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
  <%= link_to "Back to llm jobs", llm_jobs_path, class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
  <%= button_to "Delete", @llm_job, method: :delete, class: "w-full sm:w-auto mt-2 sm:mt-0 sm:ml-2 rounded-md px-3.5 py-2.5 text-white bg-red-600 hover:bg-red-500 font-medium cursor-pointer", data: { turbo_confirm: "Are you sure?" } %>
</div>

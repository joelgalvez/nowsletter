<% content_for :title, "Tags" %>

<div class="crud">
  <% if notice.present? %>
    <p class="flash-notice" id="notice"><%= notice %></p>
  <% end %>

  <div class="page-header">
    <h1 class="page-title">Tags</h1>
    <%= link_to "New tag", new_tag_path, class: "btn-primary" %>
  </div>

  <div id="tags" class="min-w-full">
    <% @tags.each do |tag| %>
      <%= render tag %>
      <p>
        <%= link_to "Show this tag", tag, class: "ml-2 btn-secondary" %>
      </p>
    <% end %>
  </div>
</div>

<% content_for :title, "Letters" %>

<div class="crud">
  <div class="page-header">
    <h1 class="text-3xl font-bold">Letters</h1>
    <div class="flex gap-2">
      <%= link_to "New letter", new_letter_path, class: "btn-primary" %>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-md overflow-hidden p-6 mb-8">
  
    <div class="flex items-start gap-0">
      <% [
        { status: "precheck",  label: "🔍 Precheck",   desc: "Awaiting confirmation" },
        { status: "ignored",   label: "🚫 Ignored",    desc: "Does not contain events" },
        { status: "pending",   label: "⏳ Pending",    desc: "LLM Server has fetched the data" },
        { status: "processed", label: "✅ Processed",  desc: "Data is made to events" },
      ].each_with_index do |step, i| %>
        <div class="flex flex-col items-center flex-1">
          <div class="flex items-center w-full">
            <div class="<%= (i == 0 || i == 1) ? 'invisible' : '' %> flex-1 h-1 bg-indigo-300"></div>
            <div class="w-4 h-4 rounded-full <%= step[:status] == 'ignored' ? 'bg-gray-400 ring-4 ring-gray-100' : 'bg-indigo-600 ring-4 ring-indigo-100' %> flex-shrink-0"></div>
            <div class="<%= (i == 3 || i == 1) ? 'invisible' : '' %> flex-1 h-1 bg-indigo-300"></div>
          </div>
          <div class="mt-3 text-center px-1">
            <div class="text-xs font-semibold text-indigo-700 uppercase tracking-wide"><%= step[:label] %></div>
            <div class="text-xs text-gray-400 mt-1 leading-tight"><%= step[:desc] %></div>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="index-card">
    <div class="index-card-header">
      <div class="sm:flex-auto">
        <p class="text-sm text-gray-600">A list of all letters.</p>
      </div>
      <div class="mt-4 sm:mt-0 sm:flex-none flex items-center gap-4">
        <%= render "shared/search_form", url: letters_path, query: @query, placeholder: "Search letters...", frame_id: "letters_list", sort: @sort, direction: @direction %>
        <span class="badge-count"><%= pluralize(@letters.total_count, 'letter') %></span>
      </div>
    </div>

    <%= turbo_frame_tag "letters_list" do %>
      <div class="index-table overflow-x-auto">
        <div class="index-row index-row-header grid grid-cols-[3fr_2fr_2fr_1fr_1fr]">
          <div class="index-th"><%= sortable "subject", "Subject", frame: "letters_list" %></div>
          <div class="index-th-label">Venue</div>
          <div class="index-th"><%= sortable "status", "Status", frame: "letters_list" %></div>
          <div class="index-th"><%= sortable "sent_date", "Sent", frame: "letters_list" %></div>
          <div class="index-th-label text-right">Actions</div>
        </div>

        <% if @letters.present? %>
          <% @letters.each do |letter| %>
            <div class="index-row grid grid-cols-[3fr_2fr_2fr_1fr_1fr] <%= letter.status == 'precheck' ? 'bg-red-50 hover:bg-red-100' : 'bg-white hover:bg-gray-50' %> transition-colors">
              <div class="index-td">
                <div class="index-td-text">
                  <% if @query.present? %>
                    <%= highlight(letter.subject.to_s, @query, highlighter: '<span class="bg-yellow-100">\1</span>') %>
                  <% else %>
                    <%= letter.subject %>
                  <% end %>
                </div>
              </div>
              <div class="index-td">
                <div class="text-sm text-gray-900"><%= letter.venue&.title || '-' %></div>
              </div>
              <div class="index-td">
                <%= form_with url: update_status_letter_path(letter), method: :patch, local: false, class: "status-form", data: { letter_id: letter.id } do |form| %>
                  <%= select_tag :status,
                      options_for_select([['🔍 Precheck', 'precheck'], ['🚫 Ignored', 'ignored'], ['⏳ Pending', 'pending'], ['✅ Processed', 'processed']], letter.status),
                      class: "status-dropdown w-full text-sm rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500",
                      data: { letter_id: letter.id } %>
                <% end %>
                <% if letter.pending_at.present? %>
                  <div class="text-xs text-gray-500 mt-1">
                    Pending since: <%= letter.pending_at.in_time_zone.strftime("%Y-%m-%d %H:%M") %>
                  </div>
                <% end %>
              </div>
              <div class="index-td-muted"><%= letter.sent_date&.strftime("%b %d, %Y") %></div>
              <div class="index-td text-right flex gap-4">
                <%= link_to "View", letter_path(letter), class: "text-indigo-600 hover:text-indigo-900", data: { turbo_frame: "_top" } %>
                <% if letter.status != "precheck" %>
                  <%= link_to "Edit", dashboard_letter_path(letter), class: "text-indigo-600 hover:text-indigo-900", data: { turbo_frame: "_top" } %>
                <% end %>
                <% if letter.events.empty? && letter.llm_jobs.empty? %>
                  <%= button_to "Delete", letter_path(letter), method: :delete,
                      data: { turbo_confirm: "Are you sure you want to delete this letter?" },
                      class: "text-red-600 hover:text-red-900" %>
                <% end %>
              </div>
              <div class="precheck-options col-span-full px-6 pt-2 pb-4 text-base font-bold text-gray-700 flex items-center justify-center gap-1 flex-wrap" style="<%= letter.status == 'precheck' ? '' : 'display:none' %>">
                <%= link_to "👁️ View", letter_path(letter), class: "text-indigo-600 hover:bg-indigo-600 hover:text-white border border-indigo-600 rounded-md px-2 py-0.5 transition-colors", data: { turbo_frame: "_top" } %> this email, confirm if needed. Does this email contain events?
                <%= button_to "✅ Yes", allow_this_and_future_letter_path(letter), method: :patch, class: "text-indigo-600 hover:bg-indigo-600 hover:text-white border border-indigo-600 rounded-md px-2 py-0.5 inline transition-colors" %>
                
                <%= button_to "❌ No", allow_future_only_letter_path(letter), method: :patch, class: "text-indigo-600 hover:bg-indigo-600 hover:text-white border border-indigo-600 rounded-md px-2 py-0.5 inline transition-colors" %>.
                Future mails will be processed automatically.

              </div>
            </div>
          <% end %>
        <% else %>
          <div class="px-6 py-8 text-center text-gray-500 bg-white">
            <% if @query.present? %>
              No letters found matching "<%= @query %>".
              <%= link_to "Clear search", letters_path(sort: @sort, direction: @direction), data: { turbo_frame: "letters_list" }, class: "text-indigo-600 hover:text-indigo-900" %>.
            <% else %>
              No letters found.
            <% end %>
          </div>
        <% end %>
      </div>

      <% if @letters.total_pages > 1 %>
        <div class="mt-4 flex justify-center pb-4">
          <%= paginate @letters, params: { sort: @sort, direction: @direction, query: @query } %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>

<% content_for :title, "Editing prompt" %>

<div class="crud">
  <h1 class="font-bold text-4xl">Editing prompt</h1>

  <%= render "form", prompt: @prompt %>

  <%= link_to "Show this prompt", @prompt, class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
  <%= link_to "Back to prompts", prompts_path, class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
</div>

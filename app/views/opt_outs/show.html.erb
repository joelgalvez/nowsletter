<% content_for :title, "Opt out" %>

<div class="crud max-w-xl">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <h1 class="font-bold text-4xl mb-6">Opt out</h1>

  <p class="mb-6 text-base">
    Opting out removes you (<strong><%= @venue.title %></strong>) completely from this website. This can be undone.
  </p>

  <%= form_with url: opt_out_path, method: :patch, class: "contents" do |form| %>
    <%= hidden_field_tag :token, params[:token] %>
    <%= hidden_field_tag :opt_out, (!@venue.opt_out).to_s %>
    <% if @venue.opt_out %>
      <%= form.submit "Opted out — click to opt back in",
            class: "rounded-md px-4 py-3 bg-gray-600 hover:bg-gray-500 text-white font-medium cursor-pointer",
            data: { turbo_confirm: "Opt #{@venue.title} back in?" } %>
    <% else %>
      <%= form.submit "Opt out",
            class: "rounded-md px-4 py-3 bg-red-600 hover:bg-red-500 text-white font-medium cursor-pointer",
            data: { turbo_confirm: "Opt #{@venue.title} out of this website?" } %>
    <% end %>
  <% end %>
</div>

<% content_for :title, "Pages" %>

<div class="crud">
  <% if notice.present? %>
    <p class="flash-notice" id="notice"><%= notice %></p>
  <% end %>

  <div class="page-header">
    <h1 class="page-title">Pages</h1>
    <%= link_to "New page", new_page_path, class: "btn-primary" %>
  </div>

  <div id="pages" class="min-w-full divide-y divide-gray-200 space-y-5">
    <% if @pages.any? %>
      <% @pages.each do |page| %>
        <div class="flex flex-col sm:flex-row justify-between items-center pb-5 sm:pb-0">
          <%= render page %>
          <div class="w-full sm:w-auto flex flex-col sm:flex-row gap-2">
            <%= link_to "Show", page, class: "btn-secondary" %>
            <%= link_to "Edit", edit_page_path(page), class: "btn-secondary" %>
            <%= button_to "Destroy", page, method: :delete, class: "btn-danger", data: { turbo_confirm: "Are you sure?" } %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-center my-10">No pages found.</p>
    <% end %>
  </div>
</div>

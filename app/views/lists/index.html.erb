<% content_for :title, "Lists" %>

<div class="crud">
  <% if notice.present? %>
    <p class="flash-notice" id="notice"><%= notice %></p>
  <% end %>

  <div class="page-header">
    <h1 class="page-title">Lists</h1>
    <%= link_to "New list", new_list_path, class: "btn-primary" %>
  </div>

  <div id="lists" class="min-w-full">
    <% @lists.each do |list| %>
      <%= render list %>
      <p>
        <%= link_to "Show this list", list, class: "ml-2 btn-secondary" %>
      </p>
    <% end %>
  </div>
</div>

      <%# <div class="flex gap-2 text-xs mt-2 <%= event.passed? "> %>
      <div class="flex gap-2 text-xs mt-2  ">

          <% if event.today? %>
            <div class="absolute right-4 top-6 text-yellow-200 bg-red-400 px-2 py-1 rounded-sm shadow-lg rotate-6 text-lg">
              Today
            </div>
          <% end %>
          <% if event.tomorrow? %>
            <div class="absolute right-4 top-6 text-red-400 bg-yellow-100 px-2 py-1 rounded-sm shadow-lg rotate-6 text-lg">
            Tomorrow
            </div>
          <% end %>
          <% if event.after_tomorrow? %>
            <div class="absolute right-4 top-6 text-red-300 bg-yellow-50 px-2 py-1 rounded-sm shadow-lg rotate-6 text-lg">
            After tomorrow
            </div>
          <% end %>
          <% if event.passed? %>
            <div class="absolute right-4 top-6 text-white bg-red-600 px-2 py-1 rounded-sm shadow-lg rotate-6 text-lg">
            EVENT PASSED, will not be shown
            </div>
          <% end %>

        <%= render 'overview/date', {start_date: event.start_date, end_date: event.end_date} %>

      </div>
      <div class="text-base @[15rem]:text-2xl leading-tight line-clamp-3">
        <%=event.title %>
      </div>
      <div class="text-sm leading-tight">
        <%=event.city&.country&.country_code %>
        <%=event.city&.name %>
      </div>
      <div class="text-sm line-clamp-3">
        <%=event.description%>
      </div>
      <div class="text-xs">
        <% event.tags.each do |tag|  %>
          <%= tag.title %>,
        <% end %>
      </div>

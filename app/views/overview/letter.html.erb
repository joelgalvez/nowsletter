<%= turbo_frame_tag :popup, class: 'popup px-2' do %>
    <div 
        class="overscroll-contain fixed top-0 left-0 h-screen w-full bg-black/80 overflow-y-auto overflow-x-hidden" 
        data-controller="popup"
        data-popup-position-value="<%= @event.position %>"
        data-popup-max-value="<%= @letter.text_version.length %>"
        data-popup-search-value="<%= @event.title %>"
    >
        
        <div id="letter-root" class="max-w-[750px] mx-auto bg-white p-2 shadow-lg text-pretty relative overflow-hidden">
            <div id="letter-shadow-host"></div>
            <template id="letter-template"><%=@letter.strip_pii(@letter.display_body).html_safe%></template>
        </div>

        <div class="close cursor-pointer fixed top-8 right-8 flex gap-2 items-center text-3xl" style="filter:drop-shadow(0 0 10px black); color:white;">
            <div class="w-8 h-8">
                <svg version="1.1" baseProfile="tiny" id="Layer_1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" x="0px" y="0px" width="100%" height="100%" viewBox="0 0 20 20" xml:space="preserve">
                <line fill="#FFFFFF" stroke="#FFFFFF" stroke-width="2" stroke-miterlimit="10" x1="0.5" y1="0.5" x2="19.4" y2="19.4"/>
                <line fill="#FFFFFF" stroke="#FFFFFF" stroke-width="2" stroke-miterlimit="10" x1="19.4" y1="0.5" x2="0.5" y2="19.4"/>
                </svg>
            </div>
            <div class="">Close</div>
            
        </div>
    </div>
<% end %>
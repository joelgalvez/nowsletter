<%= turbo_frame_tag :popup, class: 'px-2' do %>
    <div 
        class="overscroll-contain fixed top-0 left-0 h-screen w-full bg-black/80 overflow-y-auto" 
		data-controller="simple-popup"
    >
        
        <div id="letter-root" class="max-w-[750px] mx-auto bg-white p-4 shadow-lg text-pretty relative min-h-screen">
			<div class="mb-4">
				<img src="<%= @event.display_lead_image %>" alt="" class="w-full">
			</div>
			<div class="mb-4 text-xl">
            	<%= render 'date', {start_date: @event.start_date, end_date: @event.end_date} %>
			</div>

			<div class="mb-4 text-3xl">
            	<%=@event.title%>
			</div>
			<div class="mb-4">
            	<%=@event.description%>
			</div>
			<div class="mb-4 underline">
				<a href=" <%= @event.url %>" target="_blank"><%= @event.url %></a>
            	
			</div>
        </div>

        <div class="close cursor-pointer fixed top-16 right-2 flex gap-2 items-center text-3xl" style="filter:drop-shadow(0 0 8px white) drop-shadow(0 0 10px white); color:black;">
            <div class="w-8 h-8">
                <svg version="1.1" baseProfile="tiny" id="Layer_1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" x="0px" y="0px" width="100%" height="100%" viewBox="0 0 20 20" xml:space="preserve">
                <line fill="#FFFFFF" stroke="#000000" stroke-width="2" stroke-miterlimit="10" x1="0.5" y1="0.5" x2="19.4" y2="19.4"/>
                <line fill="#FFFFFF" stroke="#000000" stroke-width="2" stroke-miterlimit="10" x1="19.4" y1="0.5" x2="0.5" y2="19.4"/>
                </svg>
            </div>
            <div class="">Close</div>
            
        </div>
    </div>
<% end %>
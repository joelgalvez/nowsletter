<%
  form_url = event.persisted? ? event_path(event) : events_path
  form_method = event.persisted? ? :patch : :post
%>
<%= form_with(model: event, url: form_url, method: form_method, class: "contents", data: { controller: "form-loading", action: "turbo:submit-start->form-loading#showLoading turbo:submit-end->form-loading#hideLoading" }) do |form| %>
	<div class="p-4 max-w-[60rem] mx-auto">
		<!-- Loading Overlay -->
		<div data-form-loading-target="overlay" style="display: none;" class="fixed inset-0 bg-[rgba(0,0,0,0.3)] z-50 flex items-center justify-center">
			<div class="bg-white rounded-lg p-8 flex flex-col items-center shadow-xl">
				<div class="animate-spin rounded-full h-16 w-16 border-b-4 border-blue-600 mb-4"></div>
				<p class="text-lg font-medium text-gray-700">Updating event...</p>
				<p class="text-sm text-gray-500 mt-2">Caching images, please wait</p>
			</div>
		</div>

		<% if event.errors.any? %>
			<div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-lg mt-3">
				<h2><%= pluralize(event.errors.count, "error") %> prohibited this event from being saved:</h2>

				<ul>
					<% event.errors.each do |error| %>
					<li><%= error.full_message %></li>
					<% end %>
				</ul>
			</div>
		<% end %>

		<%= form.hidden_field :venue_id %>
		<%= form.hidden_field :letter_id %>

		<div class="my-16">
			<div class="inline">
				<%= form.submit class: "rounded-md px-4 py-3 text-sm font-medium bg-blue-600 text-white inline-block cursor-pointer hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500", data: { form_loading_target: "submit" } %>
			</div>
			<div class="inline">
				<button type="button" data-action="event-modal#close" class="rounded-md px-4 py-3 text-sm font-medium bg-gray-300 text-gray-800 inline-block ml-2 hover:bg-gray-400 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500">Cancel</button>
			</div>

		</div>

		<div class="my-5">
			<%= form.label :title %>
			<%= form.text_field :title, class: "block shadow rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-full" %>
		</div>		

		<div class="grid grid-cols-2 gap-4">
			<div class="my-5">
				<%= form.label :start_date %>
				<%= form.datetime_field :start_date, class: "block shadow rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-full" %>
			</div>

			<div class="my-5">
				<%= form.label :end_date %>
				<%= form.datetime_field :end_date, class: "block shadow rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-full" %>
			</div>

		</div>
		
		<div class="my-5" data-controller="city-selector">
			<%= form.label :city_id, "City" %>
			<%= form.select :city_id,
				options_for_select(
					@cities.map { |city| 
						["#{city.country.country_code} - #{city.name}", city.id] 
					} + [["➕ Add new city...", "new"]],
					event.city_id
				),
				{ include_blank: "Select a city..." },
				class: "block shadow rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-full",
				data: { 
					"city-selector-target": "select",
					"action": "change->city-selector#toggleNewCityInput"
				} %>
			
			<div class="mt-3 hidden" data-city-selector-target="newCityContainer">
				<div class="grid grid-cols-2 gap-2">
					<div>
						<select class="block shadow rounded-md border border-gray-400 outline-none px-3 py-2 w-full"
							data-city-selector-target="countryCodeInput">
							<option value="">Select Country...</option>
							<% @all_countries.each do |code, name| %>
								<option value="<%= code %>"><%= code %> - <%= name %></option>
							<% end %>
						</select>
					</div>
					<div>
						<input type="text" 
							placeholder="City Name (e.g., New York)"
							class="block shadow rounded-md border border-gray-400 outline-none px-3 py-2 w-full"
							data-city-selector-target="cityNameInput">
					</div>
				</div>
				<button type="button"
					class="mt-2 px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700"
					data-city-selector-target="addButton"
					data-action="click->city-selector#addNewCity">
					Add City
				</button>
			</div>
			
			<div class="hidden" data-city-selector-target="feedback"></div>
		</div>



		<div class="my-5" 
			data-controller="event-tag-selector" 
			data-event-tag-selector-tags-value="<%= (event.tags || []).map { |tag| { id: tag.id, title: tag.title || tag.name } }.to_json %>"
			data-event-tag-selector-search-url-value="/dashboard/tags/search">
			<%= form.label :tags, "Tags", class: "block text-sm font-medium text-gray-700 mb-2" %>
			
			<div class="flex flex-wrap gap-2 mb-3" data-event-tag-selector-target="selectedTags">
				<!-- Tags will be rendered by Stimulus controller -->
			</div>
			
			<div class="relative">
				<input type="text" 
					data-event-tag-selector-target="searchInput"
					data-action="input->event-tag-selector#search keydown->event-tag-selector#onSearchKeydown"
					placeholder="search for tags..." 
					class="block w-full shadow rounded-md border border-gray-400 outline-none px-3 py-2 lowercase"
					autocomplete="off"
					style="text-transform: lowercase;">
				<div data-event-tag-selector-target="suggestions" class="absolute z-10 w-full mt-1 bg-white border border-gray-300 rounded-md shadow-lg hidden max-h-60 overflow-auto">
					<div class="p-2 text-center text-gray-500 hidden" data-event-tag-selector-target="loading">Loading...</div>
					<div class="p-2 text-center text-gray-500 hidden" data-event-tag-selector-target="noResults">No tags found</div>
					<div data-event-tag-selector-target="results"></div>
				</div>
			</div>
			
			<div data-event-tag-selector-target="hiddenContainer">
				<% (event.tags || []).each do |tag| %>
					<%= hidden_field_tag "event[tag_ids][]", tag.id, id: "tag-id-#{tag.id}" %>
				<% end %>
			</div>
		</div>

		

		<div class="my-5 hidden">
			<%= form.label :lead_image %>
			<%= form.text_field :lead_image, id: "event_lead_image", class: "block shadow rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-full" %>
		</div>

		<div class="grid md:grid-cols-2 my-5 ">
			<div class="max-w-[15rem]">
				<img src="<%=event.lead_image%>" alt="" id="event_lead_image_preview" style="<%= event.lead_image.blank? ? 'display:none;' : '' %>">
				<div id="no_image_placeholder" style="<%= event.lead_image.present? ? 'display:none;' : '' %>" class="w-full h-32 flex items-center justify-center bg-gray-100 rounded">
					<svg viewBox="0 0 100 100" class="w-16 h-16" preserveAspectRatio="none">
						<line x1="2" y1="2" x2="96" y2="96" stroke="black" vector-effect="non-scaling-stroke"></line>
						<line x1="96" y1="2" x2="2" y2="96" stroke="black" vector-effect="non-scaling-stroke"></line>
					</svg>
				</div>
				
			</div>
			<div class="">
				<% if @images.present? %>
					<% blacklisted_urls = Blacklist.pluck(:url) %>
					<% available_images = @images.reject { |img| blacklisted_urls.include?(img) } %>
					<% if available_images.present? %>
						<p class="text-sm font-medium mb-2">Pick a different image</p>
						<button type="button" 
							class="mb-3 px-4 py-2 bg-gray-200 hover:bg-gray-300 text-gray-700 rounded-md text-sm font-medium"
							onclick="document.getElementById('event_lead_image').value=''; document.getElementById('event_lead_image_preview').src=''; document.getElementById('event_lead_image_preview').style.display='none'; document.getElementById('no_image_placeholder').style.display='flex';">
							Select no image
						</button>
						<div class="grid grid-cols-5">
							<% available_images.each_with_index do |img_url, index| %>
								<div class="w-full h-full outline-1 outline-gray-200 p-1  flex items-center justify-center">
									<%= image_tag img_url, 
										class: "max-w-full max-h-full object-contain object-center  cursor-pointer ",
										style: "aspect-ratio: 1/1;", 
										alt: "Image #{index + 1}",
										onclick: "document.getElementById('event_lead_image').value='#{img_url}'; document.getElementById('event_lead_image_preview').src='#{img_url}'; document.getElementById('event_lead_image_preview').style.display='block'; document.getElementById('no_image_placeholder').style.display='none';" %>

								</div>
							<% end %>
						</div>
					<% else %>
						<p class="text-sm text-gray-500">All images have been blacklisted. No images available for selection.</p>
					<% end %>
				<% end %>
			</div>

		</div>
		


		<div class="my-16">
			<div class="inline">
				<%= form.submit class: "rounded-md px-4 py-3 text-sm font-medium bg-blue-600 text-white inline-block cursor-pointer hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500", data: { form_loading_target: "submit" } %>
			</div>
			<div class="inline">
				<button type="button" data-action="event-modal#close" class="rounded-md px-4 py-3 text-sm font-medium bg-gray-300 text-gray-800 inline-block ml-2 hover:bg-gray-400 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500">Cancel</button>
			</div>

		</div>

	</div>  

  
<% end %>

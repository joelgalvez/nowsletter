<div id="event-<%= event.id %>" class="grid grid-cols-[10rem_1fr] gap-4 my-16 ">
	<div class="">
		<div class="grid gap-4">
			<div class="">
				<%= link_to "Edit Event", edit_dashboard_event_path(event),
					data: { turbo_frame: "event_modal" },
					class: "inline-flex w-[10rem] justify-center items-center px-4 py-3 hover:text-white text-sm font-medium  border-black border rounded-md hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>

			</div>
			<div class="">
				<div class="flex items-center gap-2 max-w-[20rem]"
					data-controller="publish-toggle"
					data-publish-toggle-url-value="<%= toggle_status_event_path(event) %>"
					data-publish-toggle-published-value="<%= event.status == 'published' %>">
					<button type="button"
						data-action="click->publish-toggle#toggle"
						data-publish-toggle-target="switch"
						class="relative inline-flex h-6 w-11 items-center rounded-full transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 <%= event.status == 'published' ? 'bg-green-600' : 'bg-gray-300' %>">
						<span data-publish-toggle-target="slider"
							class="inline-block h-4 w-4 transform rounded-full bg-white transition-transform <%= event.status == 'published' ? 'translate-x-6' : 'translate-x-1' %>"></span>
					</button>
					<span class="text-sm inline-block <%= event.status == 'published' ? 'text-black' : 'text-gray-500' %>"
						data-publish-toggle-target="text">
						<%= event.status == 'published' ? 'Published' : 'Unpublished' %>
					</span>

				</div>

			</div>
		</div>
	</div>
	<div class="relative">
		<% if event.lead_image.present? %>
			<div class="absolute top-8 left-1 z-10">
				<div class="hover:text-red-500 p-1 bg-white m-1 rounded-md shadow cursor-pointer">
					<%= button_to "❌ No image", remove_image_event_path(event), method: :patch, class: "cursor-pointer" %>
				</div>
				<div class="hover:text-red-500 p-1 bg-white m-1 rounded-md shadow cursor-pointer">
					<%= button_to "🚫 Blacklist", blacklist_image_event_path(event), method: :patch, class: "cursor-pointer" %>
				</div>
			</div>
		<% end %>
		<%= link_to_letter(event) do %>
			<%= render 'overview/event_header', event: event %>
			<%= render 'overview/event_image', event: event, use_cache: false %>
			<%= render 'overview/event_body', event: event %>
		<% end %>
	</div>

</div>

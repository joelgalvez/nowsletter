<div class="max-w-4xl mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold mb-6">Dashboard</h1>
  
  <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-6">
    <h2 class="text-xl font-semibold mb-2">No Letters Available</h2>
    <p class="text-gray-700">
      <% if Current.user.admin? %>
        There are no letters in the system yet. Letters will appear here once they are created or imported.
      <% elsif Current.user.editor? %>
        There are no letters for your venue (<%= @venue&.title || "No venue assigned" %>) yet. Letters will appear here once they are created or imported.
      <% end %>
    </p>
    
    <% if Current.user.admin? %>
      <div class="mt-4">
        <%= link_to "Create New Letter", new_letter_path, class: "inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
        <%= link_to "View All Letters", letters_path, class: "ml-2 inline-flex items-center px-4 py-2 bg-gray-600 text-white rounded-md hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500" %>
      </div>
    <% end %>
  </div>
</div>
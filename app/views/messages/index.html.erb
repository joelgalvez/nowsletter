<% content_for :title, "Messages" %>

<div class="crud">
  <% if notice.present? %>
    <p class="flash-notice" id="notice"><%= notice %></p>
  <% end %>

  <div class="page-header">
    <h1 class="page-title">Messages</h1>
    <%= link_to "New message", new_message_path, class: "btn-primary" %>
  </div>

  <div id="messages" class="min-w-full">
    <% @messages.each do |message| %>
      <%= render message %>
      <p>
        <%= link_to "Show this message", message, class: "ml-2 btn-secondary" %>
      </p>
    <% end %>
  </div>
</div>

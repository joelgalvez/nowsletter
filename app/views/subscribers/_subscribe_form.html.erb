<%= turbo_frame_tag "subscriber_form" do %>
  <div class="bg-white rounded-lg shadow-xl p-8 md:p-12">
    <div class="text-center mb-8">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">Subscribe to Our Newsletter</h1>
      <p class="text-xl text-gray-700 mb-2">Updates every Thursday</p>
      <p class="text-gray-600">This is a non-public preview of my upcoming weekly newsletter with things to do in the arts in and around Amsterdam.</p>
    </div>

    <%= form_with(model: subscriber, url: subscribers_path, method: :post, class: "space-y-6") do |form| %>
      <% if subscriber.errors.any? %>
        <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded">
          <ul class="list-disc list-inside space-y-1">
            <% subscriber.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="space-y-4">
        <div>
          <%= form.label :email, "Email Address", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.email_field :email, required: true, value: subscriber.email, class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent", placeholder: "your@email.com" %>
        </div>

        <div>
          <%= form.label :comment, "Comment (optional)", class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.text_area :comment, rows: 3, value: subscriber.comment, class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent", placeholder: "Any thoughts or feedback?" %>
        </div>
      </div>

      <div class="pt-4">
        <%= form.submit "Subscribe", class: "w-full bg-red-500 hover:bg-red-600 text-white font-semibold px-6 py-3 rounded-lg transition cursor-pointer shadow-lg hover:shadow-xl" %>
      </div>
    <% end %>

    <div class="mt-6 text-center">
      <%= link_to "Back to Home", root_path, data: { turbo_frame: "_top" }, class: "text-sm text-gray-600 hover:text-gray-900 underline" %>
    </div>
  </div>
<% end %>

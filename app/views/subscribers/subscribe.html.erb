<div class="closing-the-lid grid lg:grid-cols-2 mx-auto">
  <div class="p-4 text text-lg lg:h-screen lg:overflow-y-auto">
    <%= turbo_frame_tag "subscriber_form" do %>

        <div class="text-2xl">
          (Work in progress) subscribe to weekly updates
        </div>

        <%= form_with(model: @subscriber, url: subscribers_path, method: :post, class: "space-y-6") do |form| %>
          <%= form.hidden_field :source, value: "subscribe_page" %>

          <% if @subscriber.errors.any? %>
            <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded">
              <ul class="list-disc list-inside space-y-1">
                <% @subscriber.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <div class="my-8">
            <div class="mb-8">
              <%= form.label :email, class: "block mb-2 text-sm" do %>
              Email Address <span class="text-red-600">(Not shared with anyone)</span>
              <% end %>
              <%= form.email_field :email, required: true, class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent", placeholder: "your@email.com" %>
            </div>
            
            <%= form.label :comment, class: "block mb-2 text-sm" do %>
              <p>Optional note to publishers <span class='text-red-600'>(Only visible newsletter authors)</span></p>
            <% end %>
            <%= form.text_area :comment, rows: 3, class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent", placeholder: "If you want, you can put something here to make yourself appear less faceless to the publishers" %>
          </div>

          <div class="">
            <%= form.submit "Subscribe", class: "w-full bg-red-500 hover:bg-red-600 text-white font-semibold px-6 py-3 rounded-lg transition cursor-pointer shadow-lg hover:shadow-xl" %>
          </div>
        <% end %>

        <div class="text-2xl mt-16">
          (Work in progress) unsubscribe from weekly updates
        </div>
      
    <% end %>
  </div>
  <div class="">

    <div class="text-white/90 bg-gray-950 p-2 min-h-screen lg:h-screen lg:overflow-y-auto">
        <div class="preview bg-white text-red-400 inline-block p-2 -rotate-12 m-4">PREVIEW</div>
      <%= render template: "digest_mailer/weekly" %>
    </div>
  </div>
</div>

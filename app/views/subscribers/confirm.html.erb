<div class="min-h-screen flex items-center justify-center bg-gray-50">
  <div class="max-w-md w-full bg-white shadow-lg rounded-lg p-8 text-center">
    <% if @subscriber && @subscriber.confirmed? %>
      <div class="text-6xl mb-4 text-green-500">✓</div>
      <h1 class="text-2xl font-bold mb-4 text-gray-900"><%= @message %></h1>
      <p class="text-gray-600 mb-6">You'll receive weekly updates every Thursday.</p>
    <% elsif @subscriber.nil? %>
      <div class="text-6xl mb-4 text-red-500">✗</div>
      <h1 class="text-2xl font-bold mb-4 text-gray-900"><%= @message %></h1>
    <% else %>
      <div class="text-6xl mb-4 text-yellow-500">⚠</div>
      <h1 class="text-2xl font-bold mb-4 text-gray-900"><%= @message %></h1>
    <% end %>

    <%= link_to "Go to homepage", root_path, class: "inline-block bg-black text-white px-6 py-3 rounded hover:bg-gray-800 transition" %>
  </div>
</div>

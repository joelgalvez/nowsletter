<div class="max-w-6xl mx-auto px-4 py-8">
  <div class="mb-6">
    <h1 class="text-3xl font-bold">Subscribers</h1>
    <p class="text-gray-600 mt-2">
      Total: <%= @subscribers.count %> |
      Confirmed: <%= @subscribers.select(&:confirmed?).count %> |
      Unconfirmed: <%= @subscribers.reject(&:confirmed?).count %>
    </p>
  </div>

  <% if @subscribers.any? %>
    <div class="bg-white border border-gray-300 rounded-lg overflow-hidden">
      <table class="w-full">
        <thead class="bg-gray-50 border-b border-gray-300">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">Email</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">Confirmed</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">Comment</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">Subscribed At</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @subscribers.each do |subscriber| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap text-sm">
                <%= subscriber.email %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm">
                <% if subscriber.confirmed? %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                    Yes
                  </span>
                <% else %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                    No
                  </span>
                <% end %>
              </td>
              <td class="px-6 py-4 text-sm text-gray-700">
                <% if subscriber.comment.present? %>
                  <%= simple_format(subscriber.comment, class: "whitespace-pre-wrap") %>
                <% else %>
                  <span class="text-gray-400 italic">No comment</span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= subscriber.created_at.strftime("%b %d, %Y %H:%M") %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm">
                <%= button_to "Delete", subscriber_path(subscriber), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this subscriber?" }, class: "text-red-600 hover:text-red-800 font-medium" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="bg-gray-50 border border-gray-300 rounded-lg p-8 text-center">
      <p class="text-gray-600">No subscribers yet.</p>
    </div>
  <% end %>
</div>

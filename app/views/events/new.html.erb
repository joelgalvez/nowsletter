<%= turbo_frame_tag(request.path.include?('/dashboard/') ? "event_modal" : "edit_events") do %>
  <div class="">
    <% if request.path.include?('/dashboard/') %>
      <%= render "dashboard/form", event: @event %>
    <% else %>
      <div class="mx-auto md:w-2/3 w-full">
        <h1 class="font-bold text-4xl">New event</h1>
        <%= render "form", event: @event %>
        <%= link_to "Back to events", events_path, class: "ml-2 rounded-lg py-3 px-5 bg-gray-100 inline-block font-medium" %>
      </div>
    <% end %>
  </div>
<% end %>

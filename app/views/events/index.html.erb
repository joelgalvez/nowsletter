<div class="crud">
  <% if notice.present? %>
    <div class="py-3 px-4 bg-green-50 mb-6 text-green-600 font-medium rounded-lg shadow-sm" id="notice">
      <%= notice %>
    </div>
  <% end %>

  <% content_for :title, "Events" %>

  <div class="flex justify-between items-center mb-8">
    <div>
      <h1 class="font-bold text-4xl text-gray-800">Events</h1>
      <p class="text-gray-500 mt-1">Manage event listings</p>
    </div>
    <%= link_to new_event_path, class: "rounded-md py-3 px-5 bg-indigo-600 text-white font-medium hover:bg-indigo-700 transition-colors shadow-sm flex items-center" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
      </svg>
      New event
    <% end %>
  </div>

  <!-- Venue Filter -->
  <div class="mb-6">
    <%= form_tag events_path, method: :get, class: "flex items-center gap-3" do %>
      <label for="venue_id" class="text-sm font-medium text-gray-700">Venue</label>
      <%= select_tag :venue_id,
            options_from_collection_for_select(@venues, :id, :title, params[:venue_id]),
            include_blank: "All venues",
            class: "rounded-md border-gray-300 shadow-sm text-sm focus:border-indigo-500 focus:ring-indigo-500",
            onchange: "this.form.submit()" %>
      <% if params[:venue_id].present? %>
        <%= link_to "Clear", events_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
      <% end %>
    <% end %>
  </div>

  <!-- Upcoming & Ongoing Events -->
  <div class="bg-white rounded-xl shadow-md overflow-hidden mb-8">
    <div class="sm:flex sm:items-center p-6 bg-green-50 border-b border-green-200">
      <div class="sm:flex-auto">
        <h2 class="text-xl font-semibold text-gray-800">Upcoming & Ongoing</h2>
        <p class="mt-2 text-sm text-gray-600">Events that are currently happening or scheduled for the future.</p>
      </div>
      <div class="mt-4 sm:mt-0 sm:flex-none">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
          <%= pluralize(@upcoming_events.total_count, 'event') %>
        </span>
      </div>
    </div>

    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Title</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Venue</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Start</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">End</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tags</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% if @upcoming_events.any? %>
            <% @upcoming_events.each do |event| %>
              <%= render partial: "events/event_row", locals: { event: event } %>
            <% end %>
          <% else %>
            <tr>
              <td colspan="7" class="px-6 py-8 text-center text-gray-500">
                No upcoming events. <%= link_to "Create a new event", new_event_path, class: "text-indigo-600 hover:text-indigo-900" %>.
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <% if @upcoming_events.total_pages > 1 %>
      <div class="px-6 py-4 border-t border-gray-200">
        <%= paginate @upcoming_events, param_name: :upcoming_page %>
      </div>
    <% end %>
  </div>

  <!-- Past Events -->
  <div class="bg-white rounded-xl shadow-md overflow-hidden">
    <div class="sm:flex sm:items-center p-6 bg-gray-100 border-b border-gray-200">
      <div class="sm:flex-auto">
        <h2 class="text-xl font-semibold text-gray-800">Past Events</h2>
        <p class="mt-2 text-sm text-gray-600">Events that have already ended.</p>
      </div>
      <div class="mt-4 sm:mt-0 sm:flex-none">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gray-200 text-gray-700">
          <%= pluralize(@past_events.total_count, 'event') %>
        </span>
      </div>
    </div>

    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Title</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Venue</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Start</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">End</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tags</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% if @past_events.any? %>
            <% @past_events.each do |event| %>
              <%= render partial: "events/event_row", locals: { event: event } %>
            <% end %>
          <% else %>
            <tr>
              <td colspan="7" class="px-6 py-8 text-center text-gray-500">
                No past events.
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <% if @past_events.total_pages > 1 %>
      <div class="px-6 py-4 border-t border-gray-200">
        <%= paginate @past_events, param_name: :past_page %>
      </div>
    <% end %>
  </div>
</div>

<div class="crud">
  <div class="mb-6">
    <h1 class="text-3xl font-bold">New User</h1>
    <p class="text-gray-600 mt-2">Create a new user account</p>
  </div>

  <%= form_with(model: @user, local: true) do |form| %>
    <% if @user.errors.any? %>
      <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded">
        <h3 class="text-red-800 font-semibold mb-2">Please fix the following errors:</h3>
        <ul class="list-disc list-inside text-red-700">
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="bg-white shadow rounded-lg p-6 space-y-6">
      <div>
        <label for="user_email_address" class="block text-sm font-medium text-gray-700 mb-2">
          Email Address <span class="text-red-500">*</span>
        </label>
        <%= form.email_field :email_address, 
            required: true,
            class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <div>
        <label for="user_password" class="block text-sm font-medium text-gray-700 mb-2">
          Password <span class="text-red-500">*</span>
        </label>
        <%= form.password_field :password, 
            required: true,
            class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <div>
        <label for="user_password_confirmation" class="block text-sm font-medium text-gray-700 mb-2">
          Confirm Password <span class="text-red-500">*</span>
        </label>
        <%= form.password_field :password_confirmation, 
            required: true,
            class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <div>
        <label for="user_role" class="block text-sm font-medium text-gray-700 mb-2">
          Role
        </label>
        <%= form.select :role, 
            options_for_select(User::ROLES, 'editor'),
            {},
            class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-indigo-500 focus:border-indigo-500" %>
        <p class="mt-1 text-sm text-gray-500">
          Admin: Full system access | Editor: Manage venue content | Parser: Email processing only
        </p>
      </div>

      <div>
        <label for="user_venue_id" class="block text-sm font-medium text-gray-700 mb-2">
          Affiliated Venue
        </label>
        <%= form.select :venue_id, 
            options_from_collection_for_select(Venue.order(:title), :id, :title),
            { include_blank: "- No venue -" },
            class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-indigo-500 focus:border-indigo-500" %>
        <p class="mt-1 text-sm text-gray-500">
          The venue this user can manage (not required for admins)
        </p>
      </div>

      <div class="flex justify-between pt-6 border-t">
        <%= link_to "Cancel", users_path, class: "px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50" %>
        <%= form.submit "Create User", class: "px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 cursor-pointer" %>
      </div>
    </div>
  <% end %>
</div>
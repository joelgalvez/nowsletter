<!DOCTYPE html>
<html>
  <head>
    <title><%= [content_for(:title).presence, ENV["APP_NAME"]].compact.join(" · ") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="time-zone" content="<%= Time.zone.tzinfo.identifier %>">
    <% if ENV["NOINDEX"] == "true" %><meta name="robots" content="noindex, nofollow"><% end %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "actiontext", "data-turbo-track": "reload" if defined?(ActionText) %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <% if ENV["PLAUSIBLE_SCRIPT_URL"].present? %>
      <script defer data-domain="<%= ENV["APP_HOST"] %>" data-api="/interesting/event" src="/interesting/script"></script>
    <% end %>


    
    <style>
      @keyframes slideDown {
        from {
          transform: translateY(-100%);
          opacity: 0;
        }
        to {
          transform: translateY(0);
          opacity: 1;
        }
      }
      
      .animate-slide-down {
        animation: slideDown 0.3s ease-out;
      }
    </style>

  </head>

  <body 
    data-controller="show" 
    data-turbo="true"    
  >   

    <!-- Notification System -->
    <% if notice.present? %>
      <div data-controller="notification"
           data-notification-auto-dismiss-value="true"
           data-notification-dismiss-after-value="5000"
           class="fixed top-0 left-0 right-0 z-50 p-4 pointer-events-none">
        <div class="max-w-4xl mx-auto">
          <div class="bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-lg shadow-lg flex items-center justify-between pointer-events-auto">
            <div class="flex items-center">
              <svg class="w-5 h-5 mr-2 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span><%= notice %></span>
            </div>
            <button data-action="click->notification#close" class="ml-4 text-green-600 hover:text-green-800 focus:outline-none">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
              </svg>
            </button>
          </div>
        </div>
      </div>
    <% end %>
    
    <% if alert.present? %>
      <div data-controller="notification"
           data-notification-auto-dismiss-value="true"
           data-notification-dismiss-after-value="5000"
           class="fixed top-0 left-0 right-0 z-50 p-4 pointer-events-none">
        <div class="max-w-4xl mx-auto">
          <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg shadow-lg flex items-center justify-between pointer-events-auto">
            <div class="flex items-center">
              <svg class="w-5 h-5 mr-2 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
              </svg>
              <span><%= alert %></span>
            </div>
            <button data-action="click->notification#close" class="ml-4 text-red-600 hover:text-red-800 focus:outline-none">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
              </svg>
            </button>
          </div>
        </div>
      </div>
    <% end %>

    <div class="fixed top-1 right-1 m-1 z-20 ">
      
      <div class="absolute -z-10 w-full h-full bg-white/50 blur-sm rounded-md"></div>
    
      <div class="w-8 h-8 cursor-pointer ml-auto " data-action="click->show#show">
        <svg width="100%" height="100%" viewBox="0 0 20 18" fill="none" xmlns="http://www.w3.org/2000/svg">			
          
          <path d="M1 4H19" stroke="black" stroke-width="1.5"/>
          <path d="M19 9H1" stroke="black" stroke-width="1.5"/>
          <path d="M1 14H19" stroke="black" stroke-width="1.5"/>

        </svg>
      </div>
    </div>

    <div class="fixed top-0 left-0 w-full h-screen hidden z-30" data-show-target="content" >
        <div class="w-full h-screen bg-black/20 fixed top-0 " data-action="click->show#hide">
        </div>
        <menu class="lg:w-[30rem] ml-8 h-screen bg-white p-2 pl-4 top-0 right-0 fixed shadow-xl ">
            <div class="cursor-pointer w-8 h-8 float-right" data-action="click->show#hide">
                <svg width="100%" height="100%" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M2 2L18 18M18 2L2 18" stroke="black" stroke-width="2"/>
                </svg>
            </div>
            <div class="text-2xl mt-8 leading-tight">
                <div class="max-w-[20rem]">
                    <%= link_to "Home", root_path %>
                </div>
                <% if !@pages.blank? %>
                    <% for page in @pages %>
                    <div class="mb-4 max-w-[20rem]">
                        <%= link_to page.title, "/#{page.slug}" %>
                    </div>
                    <% end %>
                <% end %>
                <div class="text-sm">
                    <% if authenticated? %>
                        <% if Current.user.admin? %>
                            <div class="mt-4 pt-4 border-t border-gray-200">
                                <div class="space-y-1 ">
                                    <div class="text-2xl mb-4">
                                      <%= link_to 'Dashboard', dashboard_path, class: 'block hover:text-blue-600' %>
                                      <%= link_to 'Venues', venues_path, class: 'block hover:text-blue-600' %>
                                      <%= link_to 'Inbox', letters_path, class: 'block hover:text-blue-600' %>
                                      
                                    </div>
                                    <%= link_to 'Logs', logs_path, class: 'block hover:text-blue-600' %>
                                    <%= link_to 'Users', users_path, class: 'block hover:text-blue-600' %>
                                    <%= link_to 'Events', events_path, class: 'block hover:text-blue-600' %>
                                    <%= link_to 'LLM Jobs', llm_jobs_path, class: 'block hover:text-blue-600' %>
                                    <%= link_to 'Prompts', prompts_path, class: 'block hover:text-blue-600' %>
                                    <%= link_to 'Email Templates', email_templates_path, class: 'block hover:text-blue-600' %>
                                    <%= link_to 'Available Models', available_models_path, class: 'block hover:text-blue-600' %>
                                </div>
                                <% if Current.user.email_address != 'xxx@xyyyyzzzaaa.com' %>
                                  <div class="mt-3 flex items-center gap-3"
                                    data-controller="global-settings"
                                    data-global-settings-enabled-value="<%= GlobalSetting.keep_server_up? ? 'true' : 'false' %>"
                                    data-global-settings-setting-key-value="keep_server_up"
                                    data-global-settings-setting-label-value="Keep server up">
                                    <button type="button"
                                      data-action="click->global-settings#toggle"
                                      data-global-settings-target="switch"
                                      class="relative inline-flex h-6 w-11 items-center rounded-full transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 <%= GlobalSetting.keep_server_up? ? 'bg-green-600' : 'bg-gray-300' %>">
                                      <span data-global-settings-target="slider"
                                        class="inline-block h-4 w-4 transform rounded-full bg-white transition-transform <%= GlobalSetting.keep_server_up? ? 'translate-x-6' : 'translate-x-1' %>"></span>
                                    </button>
                                    <label class="text-sm font-medium text-gray-700">Keep server up</label>
                                    <div data-global-settings-target="statusText"></div>
                                  </div>
                                <% end %>
                            </div>
                        <% elsif Current.user.editor? %>
                            <div class="mt-4 pt-4 border-t border-gray-200">
                                <div class="font-semibold mb-2">Editor Menu</div>
                                <div class="space-y-2">
                                    <%= link_to 'Dashboard', dashboard_path, class: 'block hover:text-blue-600' %>
                                </div>
                            </div>
                        <% end %>

                        <div class="mt-4 flex items-center gap-3">
                            <%= button_to 'Sign out', session_path, method: :delete %>
                            <span class="text-xs text-gray-500"><%= Current.user.email_address %></span>
                        </div>

                        <div class="mt-7">
                            <%= link_to settings_path, class: 'flex items-center gap-2 text-sm text-gray-500 hover:text-blue-600' do %>
                              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                              </svg>
                              Settings
                            <% end %>
                        </div>
                        
                    <% else %>
                        <%= link_to 'Sign in', new_session_path %>
                    <% end  %>
                </div>
                
            </div>
        </menu>
    </div>
    <main class="" id="main">
      <%= yield %>
    </main>
    <div class="px-2">
      <%= turbo_frame_tag :popup, class: 'popup px-2 relative z-20' %>
    </div>
  </body>
</html>

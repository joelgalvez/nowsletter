<% content_for :title, "Available Models" %>

<div class="crud">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center">
    <h1 class="font-bold text-4xl">Available Models</h1>
  </div>

  <div id="available_models" class="min-w-full divide-y divide-gray-200 space-y-5">
    <% if @available_models.any? %>
      <% @available_models.each do |available_model| %>
        <div class="flex flex-col sm:flex-row justify-between items-center pb-5 sm:pb-0">
          <%= render available_model %>
        </div>
      <% end %>
    <% else %>
      <p class="text-center my-10">No available models found.</p>
    <% end %>
  </div>
</div>

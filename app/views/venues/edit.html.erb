<div class="crud">

  <div class="flex justify-between items-center mb-8">
    <div>
      <h1 class="font-bold text-4xl text-gray-800">Edit Venue</h1>
      <p class="text-gray-500 mt-1">Update venue information and manage email addresses</p>
    </div>
    <%= link_to venues_path, class: "text-indigo-600 hover:text-indigo-900 font-medium flex items-center" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
      </svg>
      Back to venues
    <% end %>
  </div>

  <!-- Venue form -->
  <div class="bg-white rounded-xl shadow-md overflow-hidden p-6 mb-8">
    <h2 class="text-xl font-semibold text-gray-800 mb-4">Venue Details</h2>
    <%= render "form", venue: @venue %>
  </div>

  <%= turbo_frame_tag "venue_users_section" do %>
  <div class="grid lg:grid-cols-2 gap-8 mb-8">
    <!-- Email addresses -->
    <div class="bg-white rounded-xl shadow-md overflow-hidden">
      <div class="px-6 py-4 bg-gray-50 border-b border-gray-200 flex items-center justify-between">
        <div>
          <h2 class="text-xl font-semibold text-gray-800">Email Addresses</h2>
          <div class="text-sm text-gray-500">Collected sender emails, perhaps useful for adding users, if it comes from a regular mailbox.</div>

        </div>
        <span class="badge-count"><%= pluralize(@senders.size, 'email address') %></span>
      </div>
      <div class="p-6">
        <% if @senders.any? %>
          <% all_user_emails = User.pluck(:email_address).to_set %>
          <ul class="divide-y divide-gray-100">
            <% @senders.each do |sender| %>
              <li class="py-2">
                <% if all_user_emails.include?(sender.email) %>
                  <span class="text-sm text-gray-800"><%= sender.email %></span>
                <% else %>
                  <%= render "user_form", user: User.new(email_address: sender.email, venue_id: @venue.id) %>
                <% end %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-sm text-gray-400">No email addresses configured.</p>
        <% end %>
      </div>
    </div>

    <!-- Editors -->
    <div class="bg-white rounded-xl shadow-md overflow-hidden">
      <div class="px-6 py-4 bg-gray-50 border-b border-gray-200 flex items-center justify-between">
        <div class="">
          <h2 class="text-xl font-semibold text-gray-800">Editors</h2>
          <div class="text-sm text-gray-500">These editors gets notified of changes and can login and edit the events.</div>

        </div>
        <span class="badge-count"><%= pluralize(@users.size, 'editor') %></span>
      </div>
      <div class="p-6">
        <% if @users.any? %>
          <% @users.each do |user| %>
            <%= render "user_form", user: user %>
          <% end %>
        <% else %>
          <div class="py-4 text-center text-gray-500 mb-4">
            <p>No editors have been assigned to this venue yet.</p>
          </div>
        <% end %>

        <!-- Add new user form -->
        <div class="<%= @users.any? ? 'mt-4 pt-4 border-t border-gray-200' : '' %>">
          <h3 class="font-medium text-gray-700 mb-3">Add New Editor</h3>
          <%= render "user_form", user: @new_user %>
        </div>
      </div>
    </div>
  </div>
  <% end %>

  <div class="flex flex-wrap gap-4 mb-8">
<%= button_to @venue,
                method: :delete,
                data: { turbo_confirm: "Are you sure? This will permanently delete this venue." },
                class: "rounded-md py-2 px-4 bg-red-800 text-white font-medium hover:bg-red-900 transition-colors shadow-sm flex items-center" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
      </svg>
      Delete Venue
    <% end %>

    <%= button_to delete_events_and_letters_venue_path(@venue),
                method: :delete, 
                data: { turbo_confirm: "Are you sure? This will permanently delete all events and letters linked to this venue." }, 
                class: "rounded-md py-2 px-4 bg-red-600 text-white font-medium hover:bg-red-700 transition-colors shadow-sm flex items-center" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
      </svg>
      Delete <%= pluralize(@venue.events.count, "event") %> & <%= pluralize(@venue.letters.count, "letter") %>
    <% end %>
  </div>
</div>

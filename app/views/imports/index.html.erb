<div class="max-w-2xl mx-auto px-4 py-8">
  <div class="mb-6">
    <h1 class="text-3xl font-bold">Import</h1>
  </div>

  <%= form_with(url: import_preview_path, method: :post, local: true, data: { turbo: false }) do |form| %>
    <% if @error %>
      <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded">
        <p class="text-red-800 font-semibold"><%= @error %></p>
      </div>
    <% end %>

    <div class="bg-white shadow rounded-lg p-6 space-y-6">
      <div>
        <label for="text" class="block text-sm font-medium text-gray-700 mb-2">
          json
          <pre>
            extract event to json from the attached image or text, 
            in the following format. Select max 3 tags.
            If venue can't be found, omit the field.
            If time is missing add "00:00" as time.
            if end date or time is missing use the start date and time.
            {
              "events": [
                { "title": "TITLE",
                  "start-date-time": "YYYY-MM-DD HH:MM"
                  "end-date-time": "YYYY-MM-DD HH:MM"
                  "tags": ["tag1", "tag2", "tag3"],
                  "venue": "VENUE TITLE"
                }
              ]
            }
          </pre>
        </label>
        <%= form.text_area :text,
            value: @text,
            class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <div>
        <label for="venue_id" class="block text-sm font-medium text-gray-700 mb-2">
          Venue
        </label>
        <%= form.select :venue_id,
            options_from_collection_for_select(@venues, :id, :title, @venue_id),
            { include_blank: "- Select venue -" },
            class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <div class="flex justify-end pt-6 border-t">
        <%= form.submit "Preview", class: "px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 cursor-pointer" %>
      </div>
    </div>
  <% end %>
</div>

<h2>Pending Letters Warning</h2>

<p>There are <strong><%= @count %></strong> letters that have been in pending status for over 2 hours.</p>

<h3>Letter Details:</h3>
<table style="border-collapse: collapse; width: 100%;">
  <thead>
    <tr style="background-color: #f3f4f6;">
      <th style="border: 1px solid #e5e7eb; padding: 8px; text-align: left;">Subject</th>
      <th style="border: 1px solid #e5e7eb; padding: 8px; text-align: left;">From</th>
      <th style="border: 1px solid #e5e7eb; padding: 8px; text-align: left;">Pending Since</th>
      <th style="border: 1px solid #e5e7eb; padding: 8px; text-align: left;">Hours Pending</th>
    </tr>
  </thead>
  <tbody>
    <% @letters.each do |letter| %>
      <tr>
        <td style="border: 1px solid #e5e7eb; padding: 8px;"><%= letter.subject %></td>
        <td style="border: 1px solid #e5e7eb; padding: 8px;"><%= letter.from %></td>
        <td style="border: 1px solid #e5e7eb; padding: 8px;"><%= letter.pending_at.in_time_zone.strftime("%Y-%m-%d %H:%M") %></td>
        <td style="border: 1px solid #e5e7eb; padding: 8px;"><%= ((Time.current - letter.pending_at) / 1.hour).round(1) %> hours</td>
      </tr>
    <% end %>
  </tbody>
</table>

<p>Please review these pending letters as soon as possible.</p>
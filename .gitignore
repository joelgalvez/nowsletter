# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore all environment files except the example template.
/.env*
!/.env.example

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Ignore cached images (downloaded and processed from external sources)
/public/cached_images/*
!/public/cached_images/.keep

# Ignore master key for decrypting credentials and more.
/config/master.key

/app/assets/builds/*
!/app/assets/builds/.keep

/config/credentials/
*.enc

/config/deploy*

.DS_Store
*.bak
# Ignore key files for decrypting credentials and more.
/config/credentials/*.key
/.kamal/secrets.*

/docs-private
/scripts
.claude

/config/database.yml
/config/cache.yml
/config/cable.yml
/config/recurring.yml
/config/environments/amsterdamart.rb
.aider*

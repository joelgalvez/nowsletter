#!/bin/bash -e

# Enable jemalloc for reduced memory usage and latency.
if [ -z "${LD_PRELOAD+x}" ]; then
    LD_PRELOAD=$(find /usr/lib -name libjemalloc.so.2 -print -quit)
    export LD_PRELOAD
fi

# Fall back to example configs for any files not included in the build context
for config in database cable cache recurring; do
  if [ ! -f "config/${config}.yml" ] && [ -f "config/${config}.example.yml" ]; then
    cp "config/${config}.example.yml" "config/${config}.yml"
  fi
done

# Generate a production-equivalent environment file for custom RAILS_ENV values
if [ -n "${RAILS_ENV}" ] && [ ! -f "config/environments/${RAILS_ENV}.rb" ]; then
  echo 'require_relative "production"' > "config/environments/${RAILS_ENV}.rb"
fi

# If running the rails server then create or migrate existing database
if [ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ]; then
  ./bin/rails db:prepare
fi

exec "${@}"
